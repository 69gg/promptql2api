# PromptQL 网关配置
# 从浏览器 DevTools > Application > Cookies > auth.pro.ql.app 复制 hasura-lux 的值
HASURA_LUX=your_hasura_lux_cookie_value_here
# 项目 ID（URL 里 /project/<project_id>/ 的短横线格式 uuid）
PROJECT_ID=4712817f-3501-44d3-8a40-f74025a128ff
# 项目名（p-<project_id> 格式）
PROJECT_NAME=p-4712817f-3501
# 时区
TIMEZONE=Asia/Shanghai
# 网关监听
HOST=0.0.0.0
PORT=8088
# 访问网关用的 API key（客户端传 Authorization: Bearer <key>；留空则不校验）
GATEWAY_API_KEY=
